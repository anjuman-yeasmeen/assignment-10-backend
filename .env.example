# MongoDB
MONGO_URI=your_mongodb_connection_string
MONGO_DB=medicare

# JWT (used to sign the auth cookie). Keep this secret.
JWT_SECRET=your_long_random_secret

# Public base URL of the app (used for OAuth redirect URIs)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Express server (5000 is taken by macOS ControlCenter/AirPlay, so use 5001 locally)
PORT=5001
NODE_ENV=development

# Comma-separated list of allowed client origins for CORS (credentials enabled)
CLIENT_ORIGINS=http://localhost:3000
